<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>International Roaming Intelligence — {{ refresh_date }}</title>
    <style>
        :root {
            --telus-purple: #4B286D;
            --telus-green: #66CC00;
            --bg-light: #F7F7F8;
            --text-primary: #2A2C2E;
            --text-secondary: #676B73;
            --border: #D8D8D8;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: var(--text-primary);
            background: var(--bg-light);
            line-height: 1.6;
        }
        header {
            background: var(--telus-purple);
            color: white;
            padding: 1.5rem 2rem;
        }
        header h1 { font-size: 1.5rem; font-weight: 600; }
        header .meta { font-size: 0.875rem; opacity: 0.85; margin-top: 0.25rem; }
        nav {
            background: white;
            border-bottom: 1px solid var(--border);
            padding: 0.75rem 2rem;
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }
        nav a {
            color: var(--telus-purple);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
        }
        nav a:hover { text-decoration: underline; }
        main { max-width: 1200px; margin: 2rem auto; padding: 0 2rem; }
        .section {
            background: white;
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .section h2 {
            color: var(--telus-purple);
            font-size: 1.25rem;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--telus-green);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }
        th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid var(--border); }
        th { background: var(--bg-light); font-weight: 600; color: var(--text-secondary); }
        footer {
            text-align: center;
            padding: 2rem;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }
    </style>
</head>
<body>
    <header>
        <h1>International Roaming Intelligence</h1>
        <div class="meta">Report Date: {{ refresh_date }} | Generated by pipeline step 6</div>
    </header>

    <nav>
        <a href="#executive-summary">Executive Summary</a>
        <a href="#country-overview">Country Overview</a>
        <a href="#carrier-rankings">Carrier Rankings</a>
        <a href="#trends">Trends</a>
        <a href="#usage">Usage Analytics</a>
        <a href="#data-quality">Data Quality</a>
    </nav>

    <main>
        {# Section content injected by report builder — implemented in Epic 3 #}
        {% for section_id, section_html in sections.items() %}
        <div class="section" id="{{ section_id }}">
            {{ section_html | safe }}
        </div>
        {% endfor %}

        {% if not sections %}
        <div class="section">
            <h2>Report Skeleton</h2>
            <p>Section content will be added in Epic 3 (Stories 3.2–3.7).</p>
        </div>
        {% endif %}
    </main>

    <footer>
        TELUS — International Roaming Intelligence | Carrier Steering Team | Confidential
    </footer>
</body>
</html>
